# Teacher Assistant App — Environment Variables
# Copy this file to .env and fill in the values.
# For first-time setup, run setup-env.sh (Linux/macOS) or setup-env.ps1 (Windows)
# to auto-generate secure values.

# ─────────────────────────────────────────────
# REQUIRED — App will throw on startup if missing
# ─────────────────────────────────────────────

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_secure_random_string

# Initial admin account password. App throws on startup if not set.
DEFAULT_ADMIN_PASSWORD=change_this_to_a_secure_password

# ─────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────

# Set to 'production' to enable Helmet CSP and serve static files.
# NODE_ENV=production

# Comma-separated list of allowed origins for WebSocket CORS (optional)
# Defaults to localhost if not set. Use '*' to allow all (not recommended in production)
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.50:3000

# PostgreSQL connection string (optional — app uses SQLite by default).
# If set and reachable, the app auto-detects and uses PostgreSQL.
# DATABASE_URL=postgresql://user:password@localhost:5432/teacher_assistant

# Performance Monitoring Configuration (optional)
# Threshold for slow HTTP requests in milliseconds (default: 1000)
# PERF_SLOW_REQUEST_MS=1000

# Threshold for slow database queries in milliseconds (default: 100)
# PERF_SLOW_QUERY_MS=100

# Log all requests regardless of speed (default: true in dev, false in prod)
# PERF_LOG_ALL_REQUESTS=false

# Seed script only — passwords for demo users (defaults to *_placeholder if unset)
# DEMO_TEACHER_PASSWORD=your_demo_password
# JOHN_DOE_PASSWORD=your_john_doe_password