# JWT Secret Key - REQUIRED
# Generate a strong secret using: openssl rand -hex 32
# Or use any long random string (minimum 32 characters recommended)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Database Configuration
# SQLite (default):
# DB_PATH=./data/database.sqlite

# PostgreSQL (when migrating):
# DATABASE_URL=postgresql://user:password@localhost:5432/teacher_assistant

# Server Configuration (optional)
# NODE_ENV=development
