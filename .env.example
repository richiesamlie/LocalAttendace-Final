# JWT Secret Key - Optional
# A default is used if not set (for development only)
# Generate a strong secret using: openssl rand -hex 32
# JWT_SECRET=your_jwt_secret_here_change_in_production

# Database Configuration
# SQLite (default - no configuration needed)
# DB_TYPE=sqlite

# PostgreSQL (optional - for production/multi-user)
# The app auto-detects PostgreSQL if DATABASE_URL is set and accessible
# DATABASE_URL=postgresql://user:password@localhost:5432/teacher_assistant

# Server Configuration (optional)
# NODE_ENV=development